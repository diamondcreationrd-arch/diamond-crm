# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/diamond_crm"

# ─── AUTH ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── EMAIL (Resend — resend.com) ──────────────────────────────────────────────
RESEND_API_KEY="re_..."

# ─── SMS (Twilio — twilio.com) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1..."

# ─── META ADS ─────────────────────────────────────────────────────────────────
META_APP_ID="..."
META_APP_SECRET="..."
META_WEBHOOK_VERIFY_TOKEN="choose-a-secret-string"

# ─── TIKTOK ADS ───────────────────────────────────────────────────────────────
TIKTOK_APP_ID="..."
TIKTOK_APP_SECRET="..."

# ─── GOOGLE ADS ───────────────────────────────────────────────────────────────
GOOGLE_WEBHOOK_SECRET="choose-a-secret-string"
